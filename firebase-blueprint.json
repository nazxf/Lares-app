{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and authentication data.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "storeId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "cashier"] },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Store": {
      "title": "Store",
      "description": "Tenant store details.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "ownerId", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product for sale or stock.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "sellingPrice": { "type": "number" },
        "purchasePrice": { "type": "number" },
        "stock": { "type": "number" },
        "minimumStock": { "type": "number" },
        "unitType": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "category", "sellingPrice", "purchasePrice", "stock", "minimumStock", "unitType", "status", "createdAt", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A specific transaction (sale or stock in).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["sale", "stock_in"] },
        "items": {
          "type": "array",
          "items": { "$ref": "TransactionItem" }
        },
        "totalAmount": { "type": "number" },
        "cashierId": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["type", "items", "totalAmount", "cashierId", "createdAt"]
    },
    "TransactionItem": {
      "title": "TransactionItem",
      "description": "Item in a transaction",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "subtotal": { "type": "number" }
      },
      "required": ["productId", "productName", "quantity", "price", "subtotal"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Record for change in product stock.",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "type": { "type": "string", "enum": ["sale", "stock_in"] },
        "quantity": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["productId", "type", "quantity", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles. Anyone can read their own profile."
    },
    "/stores/{storeId}": {
      "schema": { "$ref": "Store" },
      "description": "Store profiles."
    },
    "/stores/{storeId}/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Products belonging to a store."
    },
    "/stores/{storeId}/transactions/{transactionId}": {
      "schema": { "$ref": "Transaction" },
      "description": "Transactions belonging to a store."
    },
    "/stores/{storeId}/stock_movements/{movementId}": {
      "schema": { "$ref": "StockMovement" },
      "description": "Stock movements for products in a store."
    }
  }
}
