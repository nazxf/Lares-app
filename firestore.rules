rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function getUserRecord() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStoreMember(storeId) {
      return getUserRecord().storeId == storeId;
    }

    function isStoreOwner(storeId) {
      let user = getUserRecord();
      return user.storeId == storeId && user.role == 'owner';
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'role', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             (data.role == 'owner' || data.role == 'cashier') &&
             data.createdAt is number &&
             (!('storeId' in data) || (data.storeId is string && data.storeId.size() <= 128));
    }

    function isValidStore(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.name is string && data.name.size() <= 200 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.createdAt is number;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'sellingPrice', 'purchasePrice', 'stock', 'minimumStock', 'unitType', 'status', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 10 &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.sellingPrice is number &&
             data.purchasePrice is number &&
             data.stock is number &&
             data.minimumStock is number &&
             data.unitType is string && data.unitType.size() <= 50 &&
             (data.status == 'active' || data.status == 'inactive') &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'items', 'totalAmount', 'cashierId', 'createdAt']) &&
             data.keys().size() <= 6 &&
             (data.type == 'sale' || data.type == 'stock_in') &&
             data.items is list &&
             (data.items.size() == 0 || (
               data.items[0] is map &&
               data.items[0].keys().hasAll(['productId', 'productName', 'quantity', 'price', 'subtotal']) &&
               data.items[0].productId is string && data.items[0].productName is string &&
               data.items[0].quantity is number && data.items[0].price is number && data.items[0].subtotal is number
             )) &&
             data.totalAmount is number &&
             data.cashierId is string && data.cashierId.size() <= 128 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             data.createdAt is number;
    }

    function isValidStockMovement(data) {
      return data.keys().hasAll(['productId', 'type', 'quantity', 'createdAt']) &&
             data.keys().size() <= 5 &&
             data.productId is string && data.productId.size() <= 128 &&
             (data.type == 'sale' || data.type == 'stock_in') &&
             data.quantity is number &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 1000)) &&
             data.createdAt is number;
    }

    // --- Core Match Blocks ---

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      // Allow user creation by themselves (first sign in)
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming()) &&
        (
          // Allow profile name / role update if required
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'storeId'])
        );
    }

    // Stores
    match /stores/{storeId} {
      allow get: if isSignedIn() && isValidId(storeId) && isStoreMember(storeId);
      allow list: if false; // Users shouldn't query stores globally
      allow create: if isSignedIn() &&
                    isValidId(storeId) &&
                    isValidStore(incoming()) &&
                    incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(storeId) && isValidStore(incoming()) && isStoreOwner(storeId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name']);
      
      // Store sub-collections
      match /products/{productId} {
        allow get: if isSignedIn() && isValidId(storeId) && isValidId(productId) && isStoreMember(storeId);
        allow list: if isSignedIn() && isValidId(storeId) && isStoreMember(storeId);
        // Only owners and cashiers can create products. Let's say all members can.
        allow create: if isSignedIn() && isValidId(storeId) && isValidId(productId) && isStoreMember(storeId) &&
                      isValidProduct(incoming());
        allow update: if isSignedIn() && isValidId(storeId) && isValidId(productId) && isStoreMember(storeId) &&
                      isValidProduct(incoming()) &&
                      // Enforce immutable createdAt fields
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'sellingPrice', 'purchasePrice', 'stock', 'minimumStock', 'unitType', 'status', 'updatedAt']);
        allow delete: if false; // use inactive status
      }

      match /transactions/{transactionId} {
        allow get: if isSignedIn() && isValidId(storeId) && isValidId(transactionId) && isStoreMember(storeId);
        allow list: if isSignedIn() && isValidId(storeId) && isStoreMember(storeId);
        allow create: if isSignedIn() && isValidId(storeId) && isValidId(transactionId) && isStoreMember(storeId) &&
                      isValidTransaction(incoming()) &&
                      incoming().cashierId == request.auth.uid;
        allow update, delete: if false; // Transactions are immutable
      }

      match /stock_movements/{movementId} {
        allow get: if isSignedIn() && isValidId(storeId) && isValidId(movementId) && isStoreMember(storeId);
        allow list: if isSignedIn() && isValidId(storeId) && isStoreMember(storeId);
        allow create: if isSignedIn() && isValidId(storeId) && isValidId(movementId) && isStoreMember(storeId) &&
                      isValidStockMovement(incoming()) &&
                      exists(/databases/$(database)/documents/stores/$(storeId)/products/$(incoming().productId));
        allow update, delete: if false; // Stock movements are immutable
      }
    }
  }
}
